# Clover Wallet Monorepo Ignore

# OS
.DS_Store
*.swp

# Secrets
.env
.env.*
!**/.env.example

# Turborepo
.turbo
node_modules/

# Backend (Kotlin/Gradle)
backend/.gradle
backend/build
backend/out
backend/bin
backend/.idea

# Frontend (RN/Expo)
frontend/node_modules/
frontend/.expo/
frontend/dist/
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
apps/frontend/.expo/
apps/frontend/dist/

# Shared package build output
packages/shared/dist/

# AI Logs
logs/
*.log
docs/*/sessions/session_*.md
!docs/*/sessions/next_session.md
coverage/
lcov.info
*.lcov
.nyc_output/

.github/copilot-instructions.md

.cursorrules

