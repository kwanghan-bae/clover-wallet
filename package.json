{
  "name": "clover-wallet",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "dev:backend": "turbo run dev --filter=@clover/backend",
    "dev:frontend": "turbo run dev --filter=@clover/frontend"
  },
  "packageManager": "npm@11.10.1",
  "devDependencies": {
    "turbo": "^2.5.0",
    "react": "19.2.3",
    "@types/react": "~19.1.0"
  }
}
